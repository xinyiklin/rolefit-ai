{
  // Type-check-only config for the Node server + the shared modules it imports.
  // The server runs under Node's native TypeScript type stripping (Node >= 22.18),
  // so this config never emits (noEmit) — it only enforces types. "erasable
  // syntax only": no enums, namespaces, or parameter properties, matching what
  // Node can strip. `allowImportingTsExtensions` lets the Node-executed files
  // keep their explicit `.ts` import specifiers (Node type stripping does no
  // extension resolution); `moduleResolution: bundler` resolves both those
  // explicit `.ts` specifiers and the extensionless type imports.
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "server/**/*.ts",
    "src/lib/jobIdentity.ts",
    "src/resume/sections.ts"
  ]
}
