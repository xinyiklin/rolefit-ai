{
  "name": "@typeset/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic resume typesetting engine, document model, and strict .resume codec shared by every Typeset consumer.",
  "exports": {
    "./fonts/*": "./fonts/*",
    "./*": "./src/*"
  },
  "files": [
    "src",
    "fonts"
  ],
  "scripts": {
    "eval:resume-file": "node --experimental-strip-types src/lib/__evals__/resume-file-v1.mjs",
    "eval:pdf-font-parity": "node --experimental-strip-types src/typeset/__evals__/pdf-font-parity.mjs",
    "eval": "npm run eval:resume-file && npm run eval:pdf-font-parity",
    "test": "npm run eval",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run eval",
    "fonts:check": "python3 scripts/generate_font_assets.py --check && python3 scripts/generate_pdf_fonts.py --check"
  },
  "peerDependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1",
    "react": ">=19"
  },
  "peerDependenciesMeta": {
    "@pdf-lib/fontkit": {
      "optional": true
    },
    "pdf-lib": {
      "optional": true
    }
  }
}
