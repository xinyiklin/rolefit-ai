{
  "name": "typeset-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "dev": "npm run dev --workspace apps/typeset",
    "build": "npm run build --workspace apps/typeset",
    "preview": "npm run preview --workspace apps/typeset",
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
